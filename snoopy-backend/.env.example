# ─────────────────────────────────────────────────────────────
# SNOOPY backend — local env template
# Copy to .env and fill real values from Railway → Variables tab.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3000

# --- Auth (REQUIRED) ---
JWT_SECRET=                       # >= 32 chars. Copy from Railway.
GOOGLE_CLIENT_ID=                 # Railway
GOOGLE_CLIENT_SECRET=             # Railway
# Local login redirect (Google OAuth). Prod = https://snoopy-inky.vercel.app/login
GOOGLE_REDIRECT_URI=http://localhost:4200/login

# --- Google Sheets / Drive (REQUIRED) ---
GOOGLE_SHEETS_SPREADSHEET_ID=     # Railway
GOOGLE_DRIVE_ROOT_FOLDER_ID=      # Railway

# --- Service account key: pick ONE form ---
# Local/Docker: point to a JSON file on disk
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=credentials/service-account.json
# OR cloud: paste base64 of service-account.json (then remove the PATH line above)
# GOOGLE_SERVICE_ACCOUNT_KEY_BASE64=

# --- CORS / misc (optional in dev) ---
CORS_ORIGIN=http://localhost:4200
