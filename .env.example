# ═══════════════════════════════════════════════════════════════
#  SNOOPY — Environment Variables
#  System for National Organization and Optimized Practice of Youth
#  Author: Nattapong PIMPISAN <pimpisan.cblt@gmail.com>
#
#  Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────
NODE_ENV=production
PORT=3000
APP_VERSION=1.0.0

# Number of reverse proxies in front of the app (nginx = 1).
# Required so per-user rate limiting sees the real client IP.
TRUST_PROXY_HOPS=1

# ── JWT ──────────────────────────────────────────────────────
# MUST be at least 32 chars. Generate with: openssl rand -base64 48
JWT_SECRET=your-super-secret-key-at-least-32-chars-long-here
JWT_EXPIRES_IN=8h

# ── Google OAuth 2.0 ─────────────────────────────────────────
# Get from: Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# In production this must be your real domain, e.g. https://snoopy.example.com/login
GOOGLE_REDIRECT_URI=http://localhost:4200/login

# ── Google Sheets ─────────────────────────────────────────────
# The ID from your Google Sheets URL:
# https://docs.google.com/spreadsheets/d/{SPREADSHEET_ID}/edit
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id

# ── Google Drive ─────────────────────────────────────────────
# ID of the root folder for file storage
GOOGLE_DRIVE_ROOT_FOLDER_ID=your-root-folder-id

# ── Service Account ──────────────────────────────────────────
# Path to service-account.json inside the container
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=/app/credentials/service-account.json

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins. In production set your real domain(s):
# CORS_ORIGIN=https://snoopy.example.com
CORS_ORIGIN=http://localhost:4200

# ── File Upload ───────────────────────────────────────────────
MAX_FILE_SIZE_MB=10

# ── API Docs (Swagger) ───────────────────────────────────────
# OFF by default. Set to true ONLY in non-public environments.
ENABLE_API_DOCS=false

# ── Cron ─────────────────────────────────────────────────────
# Auto-archive practice links daily at 00:01
CRON_ARCHIVE_SCHEDULE=1 0 * * *

# ── Rate Limiting ────────────────────────────────────────────
# Per client IP (works correctly because TRUST_PROXY_HOPS is set).
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=300
# Stricter limit for /api/auth (login) to slow credential abuse.
AUTH_RATE_LIMIT_MAX=20
